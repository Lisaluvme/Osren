# ============================================
# GOOGLE SHEETS DATABASE CONFIGURATION
# ============================================
# QUICK SETUP GUIDE: See GOOGLE_SHEETS_SETUP.md for detailed instructions
#
# The app needs Service Account credentials to write to Google Sheets.
# OAuth credentials alone won't work - you need server-to-server credentials.

# 1. Create Google Cloud Service Account
#    - Go to https://console.cloud.google.com/
#    - IAM & Admin > Service Accounts > Create Service Account
#    - Download JSON key file

# 2. Share your Google Sheet with the service account email
#    - Sheet must have tab named "Inventory" with proper headers
#    - Give service account "Editor" permissions

# 3. Copy values from downloaded JSON below
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_Private_Key_Here\n-----END PRIVATE KEY-----\n"
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id-here

# Alternative: Use mock data for testing
# USE_MOCK_DATA=true

# ============================================
# FRONTEND API CONFIGURATION
# ============================================
# Base URL for the backend API (default: http://localhost:5000/api)
# Note: Vite requires VITE_ prefix for environment variables in frontend code
VITE_API_BASE_URL=http://localhost:5000/api

# ============================================
# AI SERVICES CONFIGURATION
# ============================================
# Gemini API Key for AI-powered features (demand prediction, stock recommendations)
# Get your API key from: https://makersuite.google.com/app/apikey
# Note: Vite requires VITE_ prefix for environment variables in frontend code
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# ============================================
# OPTIONAL: FIREBASE CONFIGURATION
# ============================================
# Uncomment if using Firebase for authentication/storage
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
# FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
