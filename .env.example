# ============================================
# GOOGLE SHEETS DATABASE CONFIGURATION
# ============================================
# The application uses Google Sheets as a database for warehouse and inventory management.
# Follow these steps to set up Google Sheets access:

# 1. Create a Google Cloud Project:
#    - Go to https://console.cloud.google.com/
#    - Create a new project or select existing one
#    - Enable the Google Sheets API and Google Drive API

# 2. Create a Service Account:
#    - Go to IAM & Admin > Service Accounts
#    - Click "Create Service Account"
#    - Grant it "Editor" role for the project

# 3. Create and Download Key:
#    - Click on the service account email
#    - Go to "Keys" tab > "Add Key" > "Create New Key"
#    - Choose JSON format and download
#    - Open the JSON file and copy the values below

# 4. Share your Google Sheet:
#    - Create a new Google Sheet or use existing one
#    - The sheet should have a tab named "Inventory" with headers
#    - Share the sheet with the service account email (from step 2)
#    - Give it "Editor" permissions
#    - Copy the spreadsheet ID from the URL:
#      https://docs.google.com/spreadsheets/d/[SPREADSHEET_ID]/edit

# Service Account Email
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Private Key (copy the entire key including "-----BEGIN PRIVATE KEY-----" and "-----END PRIVATE KEY-----")
# Note: Keep the \n characters for line breaks
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_Private_Key_Here\n-----END PRIVATE KEY-----\n"

# Google Spreadsheet ID
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id-here

# ============================================
# FRONTEND API CONFIGURATION
# ============================================
# Base URL for the backend API (default: http://localhost:5000/api)
# Note: Vite requires VITE_ prefix for environment variables in frontend code
VITE_API_BASE_URL=http://localhost:5000/api

# ============================================
# AI SERVICES CONFIGURATION
# ============================================
# Gemini API Key for AI-powered features (demand prediction, stock recommendations)
# Get your API key from: https://makersuite.google.com/app/apikey
# Note: Vite requires VITE_ prefix for environment variables in frontend code
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# ============================================
# OPTIONAL: FIREBASE CONFIGURATION
# ============================================
# Uncomment if using Firebase for authentication/storage
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
# FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
